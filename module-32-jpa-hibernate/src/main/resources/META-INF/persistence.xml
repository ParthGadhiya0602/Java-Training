<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="jpatraining" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- List all managed entity classes explicitly -->
        <class>com.javatraining.jpa.entity.Author</class>
        <class>com.javatraining.jpa.entity.Book</class>
        <class>com.javatraining.jpa.entity.Tag</class>
        <class>com.javatraining.jpa.entity.BookDetail</class>

        <!-- Exclude unregistered classes from persistence context -->
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- Default JDBC URL — overridden per test class via JpaUtil.createEmf(dbName) -->
            <property name="jakarta.persistence.jdbc.driver"   value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:h2:mem:jpadefault;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user"     value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- create-drop: schema created on EMF open, dropped on EMF close.
                 Ideal for tests — each test class gets a completely fresh schema. -->
            <property name="hibernate.hbm2ddl.auto"    value="create-drop"/>
            <property name="hibernate.dialect"         value="org.hibernate.dialect.H2Dialect"/>

            <!-- Show SQL in test output only if you want to see what Hibernate sends.
                 Disabled by default — logback-test.xml controls verbosity instead. -->
            <property name="hibernate.show_sql"        value="false"/>
            <property name="hibernate.format_sql"      value="true"/>

            <!-- Enable statistics for N+1 / cache demonstration tests -->
            <property name="hibernate.generate_statistics" value="true"/>
        </properties>
    </persistence-unit>

</persistence>
