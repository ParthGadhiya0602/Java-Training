<!--
  Logback configuration for tests (src/test/resources/logback-test.xml).
  Logback loads this in preference to logback.xml when it is on the classpath,
  so this file controls log output during 'mvn test'.

  Keeps output compact and sets TRACE so every log level is exercisable in tests.
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{25} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="TRACE">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
